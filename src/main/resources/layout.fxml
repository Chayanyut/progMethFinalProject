<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="game.ui.GameController">
    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" spacing="12.0"
                  style="-fx-background-color: #1a1a1a; -fx-padding: 10 14 10 14;">
                <children>
                    <Button mnemonicParsing="false" text="Toggle Shop" onAction="#toggleShop"
                            style="-fx-background-color: #333; -fx-text-fill: white;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="moneyLabel" text="Balance: $500"
                           style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                </children>
            </HBox>
        </top>
        <center>
            <Pane>
                <Canvas fx:id="gameCanvas" width="2000.0" height="2000.0"/>
            </Pane>
        </center>
    </BorderPane>
    <VBox fx:id="shopPanel" alignment="TOP_CENTER" spacing="10.0" translateX="-250.0"
          StackPane.alignment="CENTER_LEFT"
          style="-fx-background-color: rgba(35,35,40,0.95); -fx-padding: 16; -fx-border-color: #555; -fx-border-width: 0 2 0 0;">
        <children>
            <Label text="Shop" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Button mnemonicParsing="false" text="Buy Dropper ($50)" onAction="#buyDropper"
                    maxWidth="1.7976931348623157E308"
                    style="-fx-background-color: #444; -fx-text-fill: white;"/>
            <Button mnemonicParsing="false" text="Buy Conveyor ($10)" onAction="#buyConveyor"
                    maxWidth="1.7976931348623157E308"
                    style="-fx-background-color: #444; -fx-text-fill: white;"/>
            <Button mnemonicParsing="false" text="Buy Upgrader ($100)" onAction="#buyUpgrader"
                    maxWidth="1.7976931348623157E308"
                    style="-fx-background-color: #444; -fx-text-fill: white;"/>
            <Button mnemonicParsing="false" text="Buy Furnace ($200)" onAction="#buyFurnace"
                    maxWidth="1.7976931348623157E308"
                    style="-fx-background-color: #444; -fx-text-fill: white;"/>
            <Label fx:id="shopHintLabel" text="Select a machine, then click the grid to place."
                   wrapText="true"
                   style="-fx-text-fill: #ccc; -fx-font-size: 11px;"/>
        </children>
        <padding>
            <Insets top="80.0" right="12.0" bottom="12.0" left="12.0"/>
        </padding>
    </VBox>
</StackPane>
