<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="game.ui.StartMenuController"
           style="-fx-background-color: #2b2b2b;">
    <children>
        <ImageView fx:id="backgroundImageView"
                   fitWidth="1024.0" fitHeight="768.0"
                   preserveRatio="false" pickOnBounds="true" opacity="0.85"/>
        <VBox alignment="CENTER" spacing="20.0">
            <Label text="Factory Tycoon"
                   style="-fx-text-fill: white; -fx-font-size: 48px; -fx-font-weight: bold;"/>
            <Button text="Play" onAction="#startGame" mnemonicParsing="false"
                    style="-fx-font-size: 18px; -fx-padding: 12 30 12 30; -fx-background-radius: 10; -fx-background-color: #3b82f6; -fx-text-fill: white;"/>
        </VBox>
    </children>
</StackPane>

